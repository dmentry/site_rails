<%= breadcrumbs [t('views.home.announces.header'), root_path], [t('app.navbar.menu.admin_options'), nil], [t('app.navbar.menu.uniq_visitors'), show_visitors_info_path], ["#{ t('app.navbar.menu.visitor_with') } u_id: #{ @visitor.first.u_id }. #{ t('app.navbar.menu.visits') }: #{ @visitor_all_visits }", nil] %>

<% @visitor.each do |visitor| %>
  <div class='d-block border rounded bg-body mb-1 mx-1 mx-lg-2 px-1 px-lg-2 py-2 bg-light'>
    <h6 class="mt-0"><span class='form_font_color mt-1'>Визит: </span><%= visitor.time_visited.strftime("%d.%m.%Y, %H:%M") %></h6>
    <h6 class="mt-0"><span class='form_font_color mt-1'>IP: </span><%= visitor.ip %></h6>
    <% coordinates_formatted = visitor.city_lat.present? && visitor.city_long.present? ? "#{ visitor.city_lat }, #{ visitor.city_long }" : nil %>
    <h6 class="mt-0"><span class='form_font_color'>Координаты: </span><%= coordinates_formatted %></h6>
    <h6 class="mt-0"><span class='form_font_color'>Просмотренная страница: </span><%= visitor.page_name %></h6>
    <h6 class="mt-0 mb-0"><span class='form_font_color'>Переход со страницы: </span><%= visitor&.referrer %></h6>
  </div>
<% end %>

<div class="pagy-bottom mt-2">
  <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
</div>
<div class='text-center'>
  <%= link_to t('views.articles.new.back'), show_visitors_info_path, class: 'btn btn-sm btn-primary mb-2 text-center' %>
</div>
